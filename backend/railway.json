{
  "$schema": "https://railway.app/railway.schema.json",
  "name": "bongo-traffic-ai",
  "build": {
    "builder": "NIXPACKS"
  },
  "deploy": {
    "startCommand": "gunicorn app:app --bind 0.0.0.0:$PORT --timeout 120 --workers 1 --preload",
    "healthcheckPath": "/health",
    "restartPolicyType": "ON_FAILURE"
  }
}
